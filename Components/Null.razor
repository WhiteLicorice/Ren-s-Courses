@* This page exists solely to satisfy BlazorStatic auto-page-discovery for the /null route.
   BlazorStatic picks up all @page directives even those without content parameters.
   Alternative: Set BlazorStaticOptions.AddPagesWithoutParameters = false and
   manually list every page you want generated. That eliminates Null.razor but
   adds maintenance. Current approach: keep Null.razor as a simple redirect. Ugh. *@
@page "/null/{*Slug}"
@page "/null"

@using BlazorStatic
@using BlazorStatic.Services
@using BlazorStaticMinimalBlog.Models
@inject NavigationManager NavManager

@code {
    // 🐌🐌🐌
    [Parameter] public string? Slug { get; set; }

    protected override void OnInitialized()
    {
        // If a user somehow lands here, bounce them back to home.
        // This shit is so ass.
        NavManager.NavigateTo("");
    }
}