@page "/"
@page "/articles/{fileName}"
@using System.Globalization
@using BlazorStatic
@using BlazorStatic.Services
@using BlazorStaticMinimalBlog.Models
@using BlazorStaticMinimalBlog.Services
@inject BlazorStaticContentService<CourseFrontMatter> blazorStaticContentService
@inject IJSRuntime JSRuntime
@inject FrontmatterStatusService StatusService

@* --- VIEW 1: HOME PAGE --- *@
@if (string.IsNullOrWhiteSpace(FileName))
{
    <div class="py-10 sm:py-16 text-center">
        <h1
            class="text-3xl font-extrabold tracking-tight text-text-main sm:text-6xl mb-6 font-mono relative z-10 break-all max-w-full no-select">
            <span class="text-accent animate-pulse">>></span>
            <span class="glitch-target inline-block" data-text="Welcome_Traveler_">Welcome_Traveler</span>
            <span class="animate-pulse">_</span>
        </h1>
        <p class="mt-4 text-lg leading-7 text-text-dim max-w-2xl mx-auto">
            @WebsiteKeys.BlogLead
        </p>
        <div class="mt-12 mb-12 w-full h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent"></div>

        <div class="text-left">
            <CourseFilter Tags="@_allTags" />
            <PostsList />
        </div>
    </div>
    return;
}

@* --- VIEW 2: ARTICLE PAGE --- *@
@if (post == null)
{
    <div class="text-center py-20">
        <p class="text-text-dim font-mono mb-4">404 - Post not found</p>
        <a href="/" class="text-accent hover:underline font-mono text-sm">Return to homepage</a>
    </div>
    return;
}

@* CONTAINER: Full width to allow sidebar to reach edges *@
<div class="w-full px-4 animate-fade-in">

    @* PERFECT CENTER GRID STRATEGY:
       1. Mobile/Tablet/Laptop (< xl): Single centered column. Sidebar hidden.
       2. Desktop (>= xl): 3 Columns. [1fr Spacer] [Content 65ch] [1fr Sidebar].
          This ensures the middle column is DEAD CENTER relative to the viewport.
    *@
    <div class="grid grid-cols-1 xl:grid-cols-[1fr_minmax(auto,65ch)_1fr] gap-8 relative max-w-[1920px] mx-auto">

        @* === LEFT SPACER (Desktop Only) === *@
        @* Keeps the grid symmetric *@
        <div class="hidden xl:block"></div>

        @* === MAIN CONTENT (Center) === *@
        <article class="min-w-0 w-full mx-auto max-w-[65ch]">

            <header class="border-b border-border-muted pb-10 pt-10 text-center">
                @* 1. Tags *@
                <div class="mb-6 flex justify-center gap-2">
                    @foreach (var tag in post.FrontMatter.Tags)
                    {
                        <a href="@blazorStaticContentService.Options.Tags.TagsPageUrl/@tag"
                            class="rounded border border-accent/50 bg-accent-dim px-2 py-1 text-xs font-medium text-accent hover:bg-accent hover:text-white transition-colors uppercase tracking-wider">
                            @tag
                        </a>
                    }
                </div>

                @* 2. Title *@
                <h1 class="text-3xl font-bold text-text-main sm:text-5xl font-mono">@post.FrontMatter.Title</h1>

                @* 3. Subtitle *@
                @if (!string.IsNullOrWhiteSpace(post.FrontMatter.Subtitle))
                {
                    <p class="mt-3 text-xl text-text-dim font-mono">@post.FrontMatter.Subtitle</p>
                }

                @* 4. Metadata *@
                <div class="mt-8 flex flex-col items-center gap-3">
                    <div
                        class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-3 text-sm text-text-dim font-mono">
                        @foreach (var author in post.FrontMatter.Authors)
                        {
                            @if (!string.IsNullOrWhiteSpace(author.GitHubUserName))
                            {
                                <a href="https://github.com/@author.GitHubUserName" target="_blank" rel="noopener noreferrer"
                                    class="flex flex-col sm:flex-row items-center gap-1 sm:gap-2 text-text-dim hover:text-accent transition-colors group">
                                    <Svg Icon="Svg.Icons.Github"
                                        SizeClasses="w-5 h-5 sm:w-4 sm:h-4 shrink-0 group-hover:text-accent" />
                                    <span class="font-medium">@(author.Nickname ?? author.Name ??
                                                                        ArticleAuthor.DEFAULT_NAME)</span>
                                </a>
                            }
                            else
                            {
                                <span class="font-medium text-text-dim">@author.Name</span>
                            }
                        }
                        <span class="hidden sm:inline text-border-muted mx-1">•</span>
                        <time>@post.FrontMatter.Published.ToString("MMMM d, yyyy", new CultureInfo("en-US"))</time>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(post.FrontMatter.DownloadLink) || post.FrontMatter.Submissions.Count > 0)
                    {
                        <div class="relative flex w-full flex-wrap items-start justify-center gap-4" data-material-actions>
                            @if (!string.IsNullOrWhiteSpace(post.FrontMatter.DownloadLink))
                            {
                                <a href="@post.FrontMatter.DownloadLink" target="_blank" rel="noopener noreferrer"
                                    data-download-action
                                    class="group mt-1 flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-text-main">
                                    <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"
                                        class="h-4 w-4 transition-transform group-hover:translate-y-0.5">
                                        <path
                                            d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" />
                                        <path
                                            d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
                                    </svg>
                                    <span class="border-b border-accent/30 pb-0.5 group-hover:border-text-main">Download</span>
                                </a>
                            }

                            @if (post.FrontMatter.Submissions.Count > 0)
                            {
                                <div class="submission-menu mt-1" data-submission-menu>
                                    <button type="button" data-submission-trigger aria-expanded="false"
                                        aria-controls="submission-menu-panel"
                                        class="group flex cursor-pointer list-none items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-text-main">
                                        <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                            <path d="M3.5 3.75A1.75 1.75 0 0 1 5.25 2h9.5a1.75 1.75 0 0 1 1.75 1.75v12.5A1.75 1.75 0 0 1 14.75 18h-9.5a1.75 1.75 0 0 1-1.75-1.75V3.75Zm6.5 1a.75.75 0 0 0-.75.75v5.19L7.53 8.97a.75.75 0 0 0-1.06 1.06l3 3a.75.75 0 0 0 1.06 0l3-3a.75.75 0 1 0-1.06-1.06l-1.72 1.72V5.5a.75.75 0 0 0-.75-.75Z" />
                                        </svg>
                                        <span class="border-b border-accent/30 pb-0.5 group-hover:border-text-main">Submit</span>
                                        <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"
                                            class="h-3.5 w-3.5 transition-transform" data-submission-chevron>
                                            <path fill-rule="evenodd" d="M5.22 7.22a.75.75 0 0 1 1.06 0L10 10.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 8.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                    <div id="submission-menu-panel"
                                        class="submission-menu-panel absolute left-1/2 top-full z-30 w-72 max-w-[calc(100vw-2rem)] -translate-x-1/2 pt-2 text-left">
                                        <div class="rounded-lg border border-border-muted bg-surface p-2 shadow-xl">
                                            <p class="px-2 pb-2 pt-1 font-mono text-xs text-text-dim">Choose a submission bin</p>
                                            <ul class="flex flex-col gap-1">
                                                @foreach (var submission in post.FrontMatter.Submissions)
                                                {
                                                    <li>
                                                        <a href="@submission.Link" target="_blank" rel="noopener noreferrer"
                                                            class="group flex min-h-10 items-center justify-between gap-3 rounded-md px-3 py-2 text-sm font-medium text-text-main transition-colors hover:bg-accent-dim hover:text-accent focus-visible:bg-accent-dim">
                                                            <span>@submission.Name</span>
                                                            <svg aria-hidden="true" viewBox="0 0 20 20" fill="currentColor"
                                                                class="h-4 w-4 shrink-0 text-text-dim transition-colors group-hover:text-accent">
                                                                <path d="M4.25 5.5A1.25 1.25 0 0 1 5.5 4.25h3a.75.75 0 0 1 0 1.5h-3a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25H14a.25.25 0 0 0 .25-.25v-3a.75.75 0 0 1 1.5 0v3A1.25 1.25 0 0 1 14.5 16h-9a1.25 1.25 0 0 1-1.25-1.25V5.5Z" />
                                                                <path d="M10.25 4.75a.75.75 0 0 1 .75-.75h4.25a.75.75 0 0 1 .75.75V9a.75.75 0 0 1-1.5 0V6.56l-4.72 4.72a.75.75 0 1 1-1.06-1.06l4.72-4.72H11a.75.75 0 0 1-.75-.75Z" />
                                                            </svg>
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </header>

            @* === MOBILE TOC (< xl) === *@
            <div class="xl:hidden mt-8 mb-4">
                <details class="group bg-surface border border-border-muted rounded-lg overflow-hidden">
                    <summary
                        class="flex items-center justify-between p-4 cursor-pointer list-none text-text-dim font-mono text-sm font-bold">
                        <span><span class="text-accent mr-2">>></span>Table of Contents</span>
                        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7">
                            </path>
                        </svg>
                    </summary>
                    <div class="p-4 pt-0 border-t border-border-muted/50">
                        <nav id="mobile-toc-content" class="mt-2"></nav>
                    </div>
                </details>
            </div>

            @* CONTENT *@
            <div class="prose max-w-none py-10">
                @for (var diagramIndex = 0; diagramIndex < post.FrontMatter.Diagrams.Count; diagramIndex++)
                {
                    <InteractiveDiagram Diagram="@post.FrontMatter.Diagrams[diagramIndex]"
                        DiagramIndex="@diagramIndex" />
                }
                @((MarkupString)post.HtmlContent)
            </div>

            <div class="border-t border-border-muted pt-8 pb-12">
                <a href=""
                    class="group flex items-center gap-2 text-sm font-medium text-text-dim hover:text-accent transition-colors">
                    <span>&larr;</span> Home
                </a>
            </div>

        </article>

        @* === RIGHT SIDEBAR (Desktop Only >= xl) === *@
        <aside class="hidden xl:block relative">
            <div class="sticky top-8 overflow-y-auto max-h-[calc(100vh-4rem)] pt-10 pl-8">
                @* TOC Container *@
                <nav id="toc-content"></nav>
            </div>
        </aside>

    </div>
</div>

@* === SCROLL TO TOP BUTTON === *@
<button id="scroll-btn"
    class="fixed bottom-8 right-8 z-50 p-2.5 rounded-full bg-accent/90 text-white shadow-lg shadow-accent/40 hover:bg-accent hover:scale-110 transition-all duration-300 transform translate-y-4 opacity-0 pointer-events-none backdrop-blur-sm"
    aria-label="Scroll to top">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
        <path fill-rule="evenodd"
            d="M11.47 2.47a.75.75 0 011.06 0l7.5 7.5a.75.75 0 11-1.06 1.06l-6.22-6.22V21a.75.75 0 01-1.5 0V4.81l-6.22 6.22a.75.75 0 11-1.06-1.06l7.5-7.5z"
            clip-rule="evenodd" />
    </svg>
</button>

@* Script Triggers *@
@* Must happen here for code labels to work, not in code-features.js. *@
<script>Prism.highlightAll();</script>

@code {
    [Parameter] public string? FileName { get; set; }
    Post<CourseFrontMatter>? post;
    IReadOnlyList<string> _allTags = [];

    protected override void OnInitialized()
    {
        _allTags = blazorStaticContentService.Posts
            .SelectMany(p => p.FrontMatter.Tags)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (string.IsNullOrWhiteSpace(FileName)) return;
        post = blazorStaticContentService.Posts.FirstOrDefault(x => x.Url == FileName);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("addCodeFeatures");
        await JSRuntime.InvokeVoidAsync("generateTOC");
        await JSRuntime.InvokeVoidAsync("initScrollButton");
        await JSRuntime.InvokeVoidAsync("initInteractiveDiagrams");
    }
}
